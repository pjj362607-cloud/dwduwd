{
  "name": "event-first-ops-core",
  "version": "1.0.0",
  "description": "Event-first 운영 코어 v1 — 산업자재·부품 도매유통",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "migrate": "ts-node src/db/migrate.ts",
    "test": "ts-node tests/run-tests.ts",
    "smoke": "ts-node tests/smoke/integration-smoke.test.ts",
    "test:all": "npm test && npm run smoke",
    "test:db": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit && docker compose -f docker-compose.test.yml down -v",
    "test:full": "npm run test:all && npm run test:db",
    "build:netlify": "tsc && cp index.html dist/",
    "migrate:remote": "ts-node src/db/migrate.ts",
    "start": "node dist/src/index.js",
    "render-build": "npm install && npm run build"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "zod": "^3.22.4",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "@types/aws-lambda": "^8.10.131"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}